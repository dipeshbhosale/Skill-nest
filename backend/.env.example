# Firebase Admin SDK credentials (Base64-encoded service account JSON)
# Generate with: cat firebase-service-account.json | base64 -w 0
# This is the recommended approach for CI/CD and production deployments.
# When set, this takes priority over the classpath JSON file.
FIREBASE_CREDENTIALS_BASE64=

# JWT Configuration (override defaults from application.yml)
# JWT_SECRET=your-jwt-secret-here
# JWT_EXPIRATION=86400000
